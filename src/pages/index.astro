---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CategoryCard from '../components/CategoryCard.astro';
import AgentCard from '../components/AgentCard.astro';

const categories = (await getCollection('categories')).sort(
  (a, b) => a.data.order - b.data.order
);
const allAgents = (await getCollection('agents')).filter(
  (a) => a.data.status === 'live'
);
const featured = allAgents.filter(
  (a) => a.data.featured && a.data.tier === 'curated'
);

const categoryLabels: Record<string, string> = Object.fromEntries(
  categories.map((c) => [c.id, c.data.name])
);

const agentCounts: Record<string, number> = {};
for (const a of allAgents) {
  agentCounts[a.data.category] = (agentCounts[a.data.category] ?? 0) + 1;
}

const curatedCount = allAgents.filter((a) => a.data.tier === 'curated').length;
const communityCount = allAgents.filter((a) => a.data.tier === 'community').length;

const description =
  'The directory of AI agents, vibecoded products, and AI tools for marketing, comms, and media. Browse comms agents, content agents, social agents, SEO and GEO agents, martech agents, brand agents, and media agents — all with real public URLs.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'MyAgentStack — AI agents for marketing, comms, and media',
  description,
  url: 'https://myagentstack.io',
  about: {
    '@type': 'Thing',
    name: 'AI agents for marketing and communications',
  },
  publisher: {
    '@type': 'Person',
    name: 'Sarah Evans',
    url: 'https://asksarah.ai',
    sameAs: ['https://zenmedia.com'],
  },
  hasPart: categories.map((c) => ({
    '@type': 'CollectionPage',
    name: c.data.name,
    description: c.data.tagline,
    url: `https://myagentstack.io/categories/${c.id}`,
  })),
};
---

<BaseLayout
  title="MyAgentStack — AI agents for marketing, comms, and media"
  description={description}
  jsonLd={jsonLd}
>
  <Hero
    eyebrow={`${allAgents.length} AI agents · ${categories.length} categories · all with working URLs`}
    title="AI agents, vibecoded products, and tools for"
    highlight=" marketing teams."
    subtitle="A focused directory of real AI agents — every one with a working public URL. Comms, content, social, SEO/GEO, martech, brand, and media."
    primaryCta={{ href: '/agents', label: 'Browse all agents' }}
    secondaryCta={{ href: '/submit', label: 'Submit yours' }}
  />

  <!-- Quick category strip — visible immediately, scrollable on mobile -->
  <section class="category-strip">
    <div class="container">
      <div class="strip-row" role="navigation" aria-label="Categories">
        {categories.map((c) => (
          <a class="strip-pill" href={`/categories/${c.id}`}>
            <span class="strip-name">{c.data.name}</span>
            <span class="strip-count">{agentCounts[c.id] ?? 0}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured agents — show real product up high so visitors see what's here -->
  <section class="featured-section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Featured agents</span>
        <h2>Start with these.</h2>
        <p class="muted lead">
          Hand-picked AI agents — free or open-source where possible. Every link goes to a working tool.
        </p>
      </div>
      <div class="grid grid-agents mt-lg">
        {featured.map((a) => (
          <AgentCard
            href={`/agents/${a.id}`}
            name={a.data.name}
            tagline={a.data.tagline}
            category={a.data.category}
            categoryLabel={categoryLabels[a.data.category] ?? a.data.category}
            featured={a.data.featured}
            tier={a.data.tier}
          />
        ))}
      </div>
      <div class="cta-row mt-lg">
        <a class="btn btn-ghost" href="/agents">See all {allAgents.length} agents →</a>
      </div>
    </div>
  </section>

  <!-- Full category grid — for browsers who want every option -->
  <section id="categories" class="tight">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Browse by category</span>
        <h2>Every category. One stack.</h2>
        <p class="muted lead">
          Seven categories cover the work of modern marketing — from pitching journalists to ranking in AI Overviews.
        </p>
      </div>
      <div class="grid grid-categories mt-lg">
        {categories.map((c) => (
          <CategoryCard
            href={`/categories/${c.id}`}
            name={c.data.name}
            tagline={c.data.tagline}
            count={agentCounts[c.id] ?? 0}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="why-section">
    <div class="container why-grid">
      <div>
        <span class="eyebrow">Why MyAgentStack</span>
        <h2>Real agents. Real URLs. Tiered honestly.</h2>
        <p class="muted">
          Other directories pad their counts with services, platforms, and "AI-powered" SaaS. MyAgentStack lists only
          actual AI agents, vibecoded products, and AI tools — each with a working public URL.
        </p>
        <p class="muted">
          <strong>Curated</strong> entries are tools we use ourselves. <strong>Community</strong> entries are indexed
          but not vouched for. The split is honest, so you can spend your time on what actually works.
        </p>
      </div>
      <div class="why-stats">
        <div class="stat">
          <span class="stat-num gradient-text">{curatedCount}</span>
          <span class="stat-label">curated agents</span>
        </div>
        <div class="stat">
          <span class="stat-num gradient-text">{communityCount}</span>
          <span class="stat-label">community-listed</span>
        </div>
        <div class="stat">
          <span class="stat-num gradient-text">{categories.length}</span>
          <span class="stat-label">marketing categories</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-head {
    max-width: 720px;
  }
  .lead {
    font-size: 1.05rem;
    margin-top: var(--sp-sm);
  }

  /* Category strip — keeps categories visible above the fold */
  .category-strip {
    padding: 0 0 var(--sp-md);
    border-bottom: 1px solid var(--border);
  }
  .strip-row {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding: 4px 0;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }
  .strip-row::-webkit-scrollbar { height: 4px; }
  .strip-row::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
  .strip-pill {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--text);
    text-decoration: none;
    transition: all 0.15s ease;
  }
  .strip-pill:hover {
    background: var(--card-hover);
    border-color: var(--border-strong);
    color: var(--white);
  }
  .strip-name { font-weight: 500; }
  .strip-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--violet-light);
    background: rgba(124, 58, 237, 0.15);
    padding: 2px 8px;
    border-radius: 999px;
  }

  .featured-section {
    background: linear-gradient(180deg, transparent, rgba(124, 58, 237, 0.04), transparent);
    padding-top: var(--sp-xl);
  }
  .cta-row {
    display: flex;
    justify-content: center;
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--sp-2xl);
    align-items: center;
  }
  .why-stats {
    display: grid;
    gap: var(--sp-md);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--sp-md);
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 3rem;
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }
  @media (max-width: 800px) {
    .why-grid { grid-template-columns: 1fr; gap: var(--sp-lg); }
  }
</style>
