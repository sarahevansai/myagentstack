---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CategoryCard from '../components/CategoryCard.astro';
import AgentCard from '../components/AgentCard.astro';
import Search from '../components/Search.astro';

const categories = (await getCollection('categories')).sort(
  (a, b) => a.data.order - b.data.order
);
const allAgents = (await getCollection('agents')).filter(
  (a) => a.data.status === 'live'
);
const featured = allAgents.filter(
  (a) => a.data.featured && a.data.tier === 'curated'
);

const categoryLabels: Record<string, string> = Object.fromEntries(
  categories.map((c) => [c.id, c.data.name])
);

const agentCounts: Record<string, number> = {};
for (const a of allAgents) {
  agentCounts[a.data.category] = (agentCounts[a.data.category] ?? 0) + 1;
}

const curatedCount = allAgents.filter((a) => a.data.tier === 'curated').length;
const communityCount = allAgents.filter((a) => a.data.tier === 'community').length;

// Recently added — sort by dateAdded desc, fall back to alpha for ties
const recentlyAdded = allAgents
  .filter((a) => a.data.dateAdded)
  .sort((a, b) => {
    const da = a.data.dateAdded ?? '';
    const db = b.data.dateAdded ?? '';
    return db.localeCompare(da);
  })
  .slice(0, 4);

const description =
  'The directory of AI agents, vibecoded products, and AI tools for marketing, comms, and media. Browse comms agents, content agents, social agents, SEO and GEO agents, martech agents, brand agents, and media agents — all with real public URLs.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'MyAgentStack — AI agents for marketing, comms, and media',
  description,
  url: 'https://myagentstack.io',
  about: {
    '@type': 'Thing',
    name: 'AI agents for marketing and communications',
  },
  publisher: {
    '@type': 'Person',
    name: 'Sarah Evans',
    url: 'https://asksarah.ai',
    sameAs: ['https://zenmedia.com'],
  },
  hasPart: categories.map((c) => ({
    '@type': 'CollectionPage',
    name: c.data.name,
    description: c.data.tagline,
    url: `https://myagentstack.io/categories/${c.id}`,
  })),
};
---

<BaseLayout
  title="MyAgentStack — AI agents for marketing, comms, and media"
  description={description}
  jsonLd={jsonLd}
>
  <Hero
    title="The #1 marketplace for"
    highlight=" marketing, PR, comms, and media AI agents."
    primaryCta={{ href: '/agents', label: 'Browse all agents' }}
    secondaryCta={{ href: '/submit', label: 'Submit yours' }}
  >
    <Search />
  </Hero>

  <!-- Quick category strip — visible immediately, scrollable on mobile -->
  <section class="category-strip">
    <div class="container">
      <div class="strip-row" role="navigation" aria-label="Categories">
        {categories.map((c) => (
          <a class="strip-pill" href={`/categories/${c.id}`} data-category={c.id}>
            <span class="strip-name">{c.data.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {recentlyAdded.length > 0 && (
    <section class="recent-section">
      <div class="container">
        <div class="recent-head">
          <span class="eyebrow">Recently added</span>
          <a class="recent-link" href="/agents">View all →</a>
        </div>
        <div class="grid grid-agents mt-md">
          {recentlyAdded.map((a) => (
            <AgentCard
              href={`/agents/${a.id}`}
              name={a.data.name}
              tagline={a.data.tagline}
              category={a.data.category}
              categoryLabel={categoryLabels[a.data.category] ?? a.data.category}
              featured={a.data.featured}
              tier={a.data.tier}
              rating={a.data.rating}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured agents — show real product up high so visitors see what's here -->
  <section class="featured-section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Featured agents</span>
        <h2>Start with these.</h2>
      </div>
      <div class="grid grid-agents mt-lg">
        {featured.map((a) => (
          <AgentCard
            href={`/agents/${a.id}`}
            name={a.data.name}
            tagline={a.data.tagline}
            category={a.data.category}
            categoryLabel={categoryLabels[a.data.category] ?? a.data.category}
            featured={a.data.featured}
            tier={a.data.tier}
            rating={a.data.rating}
            pricing={a.data.pricing}
          />
        ))}
      </div>
      <div class="cta-row mt-lg">
        <a class="btn btn-ghost" href="/agents">Browse the full directory →</a>
      </div>
    </div>
  </section>

  <!-- Full category grid — for browsers who want every option -->
  <section id="categories" class="tight">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Browse by category</span>
        <h2>Every category. One stack.</h2>
        <p class="muted lead">
          Seven categories cover the work of modern marketing — from pitching journalists to ranking in AI Overviews.
        </p>
      </div>
      <div class="grid grid-categories mt-lg">
        {categories.map((c) => (
          <CategoryCard
            href={`/categories/${c.id}`}
            name={c.data.name}
            tagline={c.data.tagline}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .section-head {
    max-width: 720px;
  }
  .lead {
    font-size: 1.05rem;
    margin-top: var(--sp-sm);
  }

  /* Category strip — keeps categories visible above the fold */
  .category-strip {
    padding: 0 0 var(--sp-md);
    border-bottom: 1px solid var(--border);
  }
  .strip-row {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding: 4px 0;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }
  .strip-row::-webkit-scrollbar { height: 4px; }
  .strip-row::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
  .strip-pill {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--card);
    border: 1px solid color-mix(in oklab, var(--cat-color, var(--violet-light)) 32%, transparent);
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--cat-color, var(--text));
    text-decoration: none;
    transition: all 0.15s ease;
  }
  .strip-pill:hover {
    background: color-mix(in oklab, var(--cat-color, var(--violet-light)) 14%, var(--card-hover));
    border-color: color-mix(in oklab, var(--cat-color, var(--violet-light)) 60%, transparent);
    color: var(--white);
  }
  .strip-name { font-weight: 500; }
  .recent-section {
    padding: var(--sp-xl) 0 var(--sp-md);
  }
  .recent-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-sm);
  }
  .recent-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cyan-light);
  }
  .recent-link:hover { color: var(--violet-light); }

  .featured-section {
    background: linear-gradient(180deg, transparent, rgba(124, 58, 237, 0.04), transparent);
    padding-top: var(--sp-xl);
  }
  .why-content {
    max-width: 720px;
  }
  .cta-row {
    display: flex;
    justify-content: center;
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--sp-2xl);
    align-items: center;
  }
  .why-stats {
    display: grid;
    gap: var(--sp-md);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--sp-md);
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 3rem;
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }
  @media (max-width: 800px) {
    .why-grid { grid-template-columns: 1fr; gap: var(--sp-lg); }
  }
</style>
