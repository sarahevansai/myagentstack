---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const description =
  'MyAgentStack is curated by Sarah Evans — creator of asksarah.ai and Partner at Zen Media. The opinionated, practitioner-led directory of AI agents for marketing, comms, and media.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About MyAgentStack',
  description,
  url: 'https://myagentstack.io/about',
  mainEntity: {
    '@type': 'Person',
    name: 'Sarah Evans',
    jobTitle: 'Creator of asksarah.ai · Partner, Zen Media',
    url: 'https://asksarah.ai',
    sameAs: ['https://zenmedia.com', 'https://www.linkedin.com/in/sarahevans/'],
  },
};
---

<BaseLayout title="About MyAgentStack" description={description} jsonLd={jsonLd}>
  <Hero
    eyebrow="About"
    title="Practitioner-led, not"
    highlight=" platform-led."
    subtitle="MyAgentStack is the opinionated directory of AI agents for marketing, comms, and media — curated by Sarah Evans, creator of asksarah.ai and Partner at Zen Media."
  />

  <section class="tight">
    <div class="container about-grid">
      <div class="about-main">
        <h2>Why this exists</h2>
        <p>
          AI directories like agent.ai are general-purpose and platform-built. They show what's possible. MyAgentStack
          shows what actually ships — the agents that show up in real client work every week.
        </p>

        <h2>Who curates it</h2>
        <p>
          <strong>Sarah Evans</strong> is the creator of <a href="https://asksarah.ai" rel="noopener">asksarah.ai</a> and
          Partner at <a href="https://zenmedia.com" rel="noopener">Zen Media</a>. With 20+ years building at the edge of every
          platform shift, she created <em>#journchat</em> — the first industry chat connecting journalists and PR on Twitter —
          authored <em>PR@ctical</em>, was named the #1 Business Writer on HackerNoon, and is a 3× Propel 100 Most Influential
          PR Pro and CBS Las Vegas tech contributor.
        </p>
        <p>
          Curated entries on MyAgentStack include the AI tools she ships publicly via
          <a href="https://asksarah.ai/tools" rel="noopener">asksarah.ai/tools</a>,
          <a href="https://github.com/sarahevansai" rel="noopener">github.com/sarahevansai</a>, and her
          <a href="https://stan.store/asksarahevans" rel="noopener">Stan Store</a>. Her tagline says it best:
          <em>"Challenging the speed of change."</em>
        </p>

        <h2>What gets in</h2>
        <p>
          Agents are added when they meet two tests: (1) they ship work that survives compliance and editor review, and
          (2) they're used regularly enough to stay calibrated. The bar is high on purpose — every entry should save
          you a research cycle.
        </p>

        <h2>Want your agent listed?</h2>
        <p>
          MyAgentStack is curated, not open. If you've built something marketers, comms, or media teams should know
          about, <a href="/submit">submit it here</a> — every submission is reviewed personally.
        </p>
      </div>

      <aside class="about-side">
        <div class="card">
          <h4 class="meta-h">Curated by</h4>
          <p><a href="https://asksarah.ai" rel="noopener">Sarah Evans</a></p>
          <p class="muted small">Creator, asksarah.ai</p>
          <p class="muted small">Partner, Zen Media</p>
        </div>
        <div class="card">
          <h4 class="meta-h">Recognition</h4>
          <p class="small">#1 Business Writer, HackerNoon</p>
          <p class="small">3× Propel 100 Most Influential PR</p>
          <p class="small">Creator of #journchat</p>
          <p class="small">Author of PR@ctical</p>
        </div>
        <div class="card">
          <h4 class="meta-h">Where to find her tools</h4>
          <p class="small"><a href="https://asksarah.ai/tools" rel="noopener">asksarah.ai/tools</a></p>
          <p class="small"><a href="https://github.com/sarahevansai" rel="noopener">github.com/sarahevansai</a></p>
          <p class="small"><a href="https://stan.store/asksarahevans" rel="noopener">stan.store/asksarahevans</a></p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--sp-xl);
  }
  .about-main h2 {
    margin-top: var(--sp-lg);
    font-size: 1.5rem;
  }
  .about-main p {
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .about-side {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }
  .about-side .card { padding: var(--sp-md); }
  .meta-h {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--violet-light);
    margin: 0 0 8px 0;
  }
  .about-side p {
    margin: 4px 0;
    font-size: 0.95rem;
  }
  .about-side .small { font-size: 0.85rem; }
  .about-side .muted { color: var(--text-muted); }
  @media (max-width: 800px) {
    .about-grid { grid-template-columns: 1fr; }
  }
</style>
