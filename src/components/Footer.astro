---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="brand-line">
          <span>My</span><span class="gradient-text">AgentStack</span>
        </div>
        <p class="muted footer-tag">
          AI agents, vibecoded products, and tools for marketing, comms, and media.
        </p>
      </div>
      <div>
        <h4 class="footer-h">Browse</h4>
        <ul>
          <li><a href="/agents">All agents</a></li>
          <li><a href="/categories/comms">Comms</a></li>
          <li><a href="/categories/content">Content</a></li>
          <li><a href="/categories/social">Social</a></li>
          <li><a href="/categories/seo-geo">SEO &amp; GEO</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer-h">More</h4>
        <ul>
          <li><a href="/categories/martech">Martech</a></li>
          <li><a href="/categories/brand">Brand</a></li>
          <li><a href="/categories/media">Media</a></li>
          <li><a href="/submit">Submit</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer-h">Curated by</h4>
        <ul>
          <li><a href="https://asksarah.ai" rel="noopener">asksarah.ai</a></li>
          <li><a href="https://zenmedia.com" rel="noopener">Zen Media</a></li>
        </ul>
      </div>
    </div>
    <hr />
    <div class="footer-bottom">
      <span class="muted">© {year} MyAgentStack. A Sarah Evans property.</span>
      <span class="muted footer-mark">
        Built for marketers. Indexed for AI.
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--sp-3xl);
    padding-bottom: var(--sp-xl);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: var(--sp-lg);
    padding-top: var(--sp-xl);
  }
  .brand-line {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--white);
    margin-bottom: var(--sp-sm);
  }
  .footer-tag {
    max-width: 320px;
    font-size: 0.9rem;
  }
  .footer-h {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--violet-light);
    margin: 0 0 var(--sp-sm) 0;
  }
  ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  ul a { color: var(--text); font-size: 0.9rem; }
  ul a:hover { color: var(--white); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-sm);
    font-size: 0.85rem;
  }
  @media (max-width: 800px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
