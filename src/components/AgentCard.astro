---
import Rating from './Rating.astro';

interface Props {
  href: string;
  name: string;
  tagline: string;
  category: string;
  categoryLabel: string;
  featured?: boolean;
  tier?: 'curated' | 'community';
  rating?: number;
}

const {
  href,
  name,
  tagline,
  category,
  categoryLabel,
  featured = false,
  tier = 'curated',
  rating,
} = Astro.props;
---

<a class="agent-card card" href={href} data-category={category} data-tier={tier}>
  <div class="agent-card-top">
    <span class="tag">{categoryLabel}</span>
    <div class="badges">
      {tier === 'curated' && (
        <span class="badge badge-curated" title="Curated by Sarah">Curated</span>
      )}
      {tier === 'community' && (
        <span class="badge badge-community" title="Community-listed">Community</span>
      )}
      {featured && <span class="featured" aria-label="Featured">★</span>}
    </div>
  </div>
  <h3 class="agent-name">{name}</h3>
  <p class="agent-tagline">{tagline}</p>
  <div class="agent-foot">
    <Rating rating={rating} size="sm" />
    <span class="agent-cta">View →</span>
  </div>
</a>

<style>
  .agent-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .agent-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }
  .badges {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 999px;
  }
  .badge-curated {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.18), rgba(6, 182, 212, 0.18));
    border: 1px solid rgba(167, 139, 250, 0.4);
    color: var(--violet-light);
  }
  .badge-community {
    background: rgba(122, 117, 143, 0.12);
    border: 1px solid rgba(122, 117, 143, 0.25);
    color: var(--text-muted);
  }
  .featured {
    color: var(--violet-light);
    font-size: 1.1rem;
  }
  .agent-name {
    font-size: 1.25rem;
    margin: 0;
    color: var(--white);
  }
  .agent-tagline {
    color: var(--text);
    font-size: 0.95rem;
    margin: 0;
    flex: 1;
  }
  .agent-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: var(--sp-sm);
    padding-top: var(--sp-sm);
    border-top: 1px solid var(--border);
  }
  .agent-cta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cyan-light);
  }
  .agent-card:hover .agent-name { color: var(--white); }
  .agent-card:hover .agent-cta { color: var(--violet-light); }
</style>
